# folio local configuration
# Copy this file to .env and fill in real values. Do not commit .env.

# Runtime
FOLIO_ENV=prod
FOLIO_DB_PATH=~/.folio/folio.db
FOLIO_TOKEN_CACHE_PATH=~/.folio/kis_token.json

# Korea Investment Securities OpenAPI - production only
# PRD scope excludes paper trading and order APIs.
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY_MAIN=your_kis_app_key
KIS_APP_SECRET_MAIN=your_kis_app_secret
KIS_CANO_MAIN=12345678
KIS_ACNT_PRDT_CD_MAIN=01
KIS_HTS_ID=your_hts_id

# LLM provider - any OpenAI-compatible chat completions endpoint.
# OpenRouter is the default, but you can also point these to OpenAI-compatible
# gateways such as LiteLLM, vLLM, Ollama bridges, or your own proxy.
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-your-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_SITE_URL=http://localhost
LLM_APP_NAME=kis-folio

# Model routing
# Default production advisor model for normal daily portfolio analysis.
LLM_MODEL_ADVISOR=anthropic/claude-sonnet-4.6

# High-capability production model for explicit deep analysis, e.g. --deep.
LLM_MODEL_ADVISOR_DEEP=anthropic/claude-opus-4.7

# Fast production model for short summaries, history formatting, and lightweight tasks.
LLM_MODEL_FAST=anthropic/claude-haiku-4.5

# Development model for iterative prompt/tool testing.
LLM_MODEL_DEV=google/gemini-3-flash-preview

# Low-cost model for smoke tests and non-critical integration checks.
LLM_MODEL_TEST=deepseek/deepseek-v3.2

# Simple extraction/classification model for JSON tagging and keyword tasks.
LLM_MODEL_EXTRACT=openai/gpt-5.4-nano

# Context and output controls. Agentic reports default to 7 analysts,
# 3 debate reviewers per debate round, and 1 final Portfolio Manager synthesis.
LLM_MAX_OUTPUT_TOKENS=1600
LLM_MAX_REPORT_TOKENS=5000
LLM_MAX_CONTEXT_CHARS=24000
LLM_MAX_AGENT_OUTPUT_CHARS=5000
